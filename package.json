{
  "name": "sens-mcp",
  "version": "0.9.0",
  "description": "A project index for Claude Code — let the model query your codebase instead of reading it all. Saves subscription usage and keeps code clean.",
  "type": "module",
  "bin": {
    "sens": "dist/cli.js",
    "sens-mcp": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/run.ts",
    "start": "node dist/cli.js",
    "dashboard": "node dist/cli.js dashboard"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "code-index",
    "dead-code",
    "ai",
    "tokens"
  ],
  "author": "Sofia",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "globby": "^16.2.1",
    "ora": "^8.2.0",
    "qrcode-terminal": "^0.12.0",
    "ts-morph": "^28.0.0",
    "web-tree-sitter": "^0.24.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tree-sitter-wasms": "^0.1.13",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
